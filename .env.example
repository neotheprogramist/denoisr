# Denoisr defaults loaded automatically by CLI scripts.
# Copy to .env and adjust for your machine/workload.

# Logging
# Optional override. If unset, logs default to:
# logs/denoisr_YYYY-MM-DD_HH-MM-SS.log
# DENOISR_LOG_FILE=logs/denoisr.log

# Pipeline entrypoint (denoisr-train)
DENOISR_RESTART=0
# Comma-separated subset: fetch,init,phase1,phase2,phase3
# DENOISR_ONLY=fetch,init,phase1

# Shared output metadata
DENOISR_OUTPUT_DIR=outputs/
DENOISR_RUN_NAME=baseline-run

# Data config (Threadripper 3970X + RTX 3060 tuned defaults)
DENOISR_PGN_URL=https://database.lichess.org/standard/lichess_db_standard_rated_2025-01.pgn.zst
DENOISR_PGN_PATH=data/lichess.pgn.zst
DENOISR_STOCKFISH_PATH=stockfish
DENOISR_STOCKFISH_DEPTH=12
DENOISR_MAX_EXAMPLES=4000000
DENOISR_WORKERS=64
DENOISR_CHUNKSIZE=1024
DENOISR_CHUNK_EXAMPLES=1000000
DENOISR_MAX_RAM_GIB=64

# Model config
DENOISR_MODEL_D_S=256
DENOISR_MODEL_NUM_HEADS=8
DENOISR_MODEL_NUM_LAYERS=15
DENOISR_MODEL_FFN_DIM=1024
DENOISR_MODEL_NUM_TIMESTEPS=100
DENOISR_MODEL_WORLD_MODEL_LAYERS=12
DENOISR_MODEL_DIFFUSION_LAYERS=6
DENOISR_MODEL_PROJ_DIM=256
DENOISR_MODEL_GRADIENT_CHECKPOINTING=0
DENOISR_MODEL_DROPOUT=0.1
DENOISR_MODEL_DROP_PATH_RATE=0.1

# Shared training config (required, fail-fast)
DENOISR_TRAIN_MAX_GRAD_NORM=2.0
DENOISR_TRAIN_WEIGHT_DECAY=0.0001
DENOISR_TRAIN_ENCODER_LR_MULTIPLIER=1.0
DENOISR_TRAIN_MIN_LR=0.000001
DENOISR_TRAIN_WARMUP_EPOCHS=10
DENOISR_AMP_DTYPE=bf16
DENOISR_TRAIN_GRADIENT_ACCUMULATION_STEPS=4
DENOISR_TRAIN_LABEL_SMOOTHING=0.1
DENOISR_TRAIN_VALUE_NOISE_PROB=0.2
DENOISR_TRAIN_VALUE_NOISE_SCALE=0.02
DENOISR_TRAIN_POLICY_TEMP_AUGMENT_PROB=0.3
DENOISR_TRAIN_THREAT_WEIGHT=0.1
DENOISR_TRAIN_POLICY_WEIGHT=2.0
DENOISR_TRAIN_VALUE_WEIGHT=0.5
DENOISR_TRAIN_CONSISTENCY_WEIGHT=1.0
DENOISR_TRAIN_DIFFUSION_WEIGHT=1.0
DENOISR_TRAIN_REWARD_WEIGHT=1.0
DENOISR_TRAIN_PLY_WEIGHT=0.1
DENOISR_TRAIN_ILLEGAL_PENALTY_WEIGHT=0.001
DENOISR_TRAIN_HARMONY_DREAM=0
DENOISR_TRAIN_HARMONY_EMA_DECAY=0.99
DENOISR_TRAIN_CURRICULUM_INITIAL_FRACTION=0.25
DENOISR_TRAIN_CURRICULUM_GROWTH=1.02
DENOISR_TQDM=0
DENOISR_PHASE1_GATE=0.50
DENOISR_PHASE2_GATE=5.0
DENOISR_GROK_TRACKING=1
DENOISR_GROK_ERANK_FREQ=1000
DENOISR_GROK_SPECTRAL_FREQ=5000
DENOISR_GROK_ONSET_THRESHOLD=0.95
DENOISR_GROKFAST=0
DENOISR_GROKFAST_ALPHA=0.99
DENOISR_GROKFAST_LAMB=0.5
# Delayed Grokfast activation knobs (applies only when DENOISR_GROKFAST=1)
DENOISR_GROKFAST_START_EPOCH=20
DENOISR_GROKFAST_PLATEAU_EPOCHS=3
DENOISR_EMA_DECAY=0.999
# Phase 1 evaluation cadence (reduce expensive extra holdout passes)
DENOISR_PHASE1_EMA_EVAL_EVERY=2
DENOISR_PHASE1_GROK_EVAL_EVERY=3

# Phase 1 (RTX 3060 12GB tuned defaults)
DENOISR_PHASE1_CHECKPOINT=outputs/init_model.pt
DENOISR_PHASE1_DATA=outputs/training_data.pt
DENOISR_PHASE1_HOLDOUT_FRAC=0.05
DENOISR_PHASE1_BATCH_SIZE=1024
DENOISR_PHASE1_EPOCHS=100
DENOISR_PHASE1_LR=0.0001
DENOISR_PHASE1_WARMUP_EPOCHS=20
DENOISR_PHASE1_WEIGHT_DECAY=0.0001
DENOISR_PHASE1_OUTPUT=outputs/phase1.pt

# Phase 2 (RTX 3060 12GB tuned defaults)
DENOISR_PHASE2_CHECKPOINT=outputs/phase1.pt
DENOISR_PHASE2_PGN=data/lichess.pgn.zst
DENOISR_PHASE2_SEQ_LEN=10
DENOISR_PHASE2_MAX_TRAJECTORIES=30000
DENOISR_PHASE2_BATCH_SIZE=1024
DENOISR_PHASE2_EPOCHS=100
DENOISR_PHASE2_LR=0.0003
DENOISR_PHASE2_OUTPUT=outputs/phase2.pt

# Phase 3
DENOISR_PHASE3_CHECKPOINT=outputs/phase2.pt
DENOISR_PHASE3_GENERATIONS=400
DENOISR_PHASE3_GAMES_PER_GEN=64
DENOISR_PHASE3_REANALYSE_PER_GEN=32
DENOISR_PHASE3_MCTS_SIMS=400
DENOISR_PHASE3_BUFFER_CAPACITY=50000
DENOISR_PHASE3_ALPHA_GENERATIONS=40
DENOISR_PHASE3_LR=0.0001
DENOISR_PHASE3_TRAIN_BATCH_SIZE=128
DENOISR_PHASE3_DIFFUSION_STEPS=8
DENOISR_PHASE3_AUX_UPDATES_PER_GEN=1
DENOISR_PHASE3_AUX_BATCH_SIZE=64
DENOISR_PHASE3_AUX_SEQ_LEN=10
DENOISR_PHASE3_AUX_LR=0.0001
DENOISR_PHASE3_SELF_PLAY_WORKERS=8
DENOISR_PHASE3_REANALYSE_WORKERS=8
DENOISR_PHASE3_OUTPUT=outputs/phase3.pt
DENOISR_PHASE3_SAVE_EVERY=10
DENOISR_PHASE3_C_PUCT=1.4
DENOISR_PHASE3_DIRICHLET_ALPHA=0.3
DENOISR_PHASE3_DIRICHLET_EPSILON=0.25
DENOISR_PHASE3_TEMPERATURE_BASE=1.0
DENOISR_PHASE3_TEMPERATURE_EXPLORE_MOVES=30
DENOISR_PHASE3_TEMPERATURE_GENERATION_DECAY=0.97
DENOISR_PHASE3_MAX_MOVES=300
DENOISR_PHASE3_REANALYSE_SIMULATIONS=100

# Data generation CLI extras
DENOISR_DATA_OUTPUT=outputs/training_data.pt
DENOISR_POLICY_TEMPERATURE=80.0
DENOISR_LABEL_SMOOTHING=0.02
# Optional random seed
# DENOISR_SEED=42

# Init / export utilities
DENOISR_INIT_OUTPUT=outputs/init_model.pt
DENOISR_EXPORT_CHECKPOINT=outputs/phase3.pt
DENOISR_EXPORT_OUTPUT=outputs/model.safetensors

# UCI / GUI defaults
DENOISR_PLAY_MODE=single
DENOISR_PLAY_DENOISING_STEPS=20
# DENOISR_PLAY_CHECKPOINT=outputs/phase3.pt
DENOISR_GUI_MODE=single
# DENOISR_GUI_CHECKPOINT=outputs/phase3.pt
