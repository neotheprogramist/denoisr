# Denoisr defaults loaded automatically by CLI scripts.
# Copy to .env and adjust for your machine/workload.

# Logging
DENOISR_LOG_FILE=logs/denoisr.log

# Optional TOML base config (not required)
# DENOISR_CONFIG=config.toml

# Pipeline entrypoint (denoisr-train)
DENOISR_RESTART=0
# Comma-separated subset: fetch,init,phase1,phase2,phase3
# DENOISR_ONLY=fetch,init,phase1

# Shared output metadata
DENOISR_OUTPUT_DIR=outputs/
# DENOISR_RUN_NAME=baseline-run

# Data config (Threadripper 3970X tuned defaults)
DENOISR_PGN_URL=https://database.lichess.org/standard/lichess_db_standard_rated_2025-01.pgn.zst
DENOISR_PGN_PATH=data/lichess.pgn.zst
# Optional; when omitted we auto-detect stockfish from PATH
# DENOISR_STOCKFISH_PATH=/usr/local/bin/stockfish
DENOISR_STOCKFISH_DEPTH=10
DENOISR_MAX_EXAMPLES=1000000
DENOISR_WORKERS=48
DENOISR_CHUNKSIZE=128
DENOISR_CHUNK_EXAMPLES=250000
DENOISR_SCRATCH_DIR=outputs/scratch

# Model config
DENOISR_MODEL_D_S=256
DENOISR_MODEL_NUM_HEADS=8
DENOISR_MODEL_NUM_LAYERS=15
DENOISR_MODEL_FFN_DIM=1024
DENOISR_MODEL_NUM_TIMESTEPS=100

# Phase 1 (RTX 3060 12GB tuned defaults)
DENOISR_PHASE1_CHECKPOINT=outputs/init_model.pt
DENOISR_PHASE1_DATA=outputs/training_data.pt
DENOISR_PHASE1_HOLDOUT_FRAC=0.05
DENOISR_PHASE1_BATCH_SIZE=128
DENOISR_PHASE1_EPOCHS=80
DENOISR_PHASE1_LR=0.0003
DENOISR_PHASE1_WARMUP_EPOCHS=5
DENOISR_PHASE1_WEIGHT_DECAY=0.0001
DENOISR_PHASE1_OUTPUT=outputs/phase1.pt

# Phase 2
DENOISR_PHASE2_CHECKPOINT=outputs/phase1.pt
DENOISR_PHASE2_PGN=data/lichess.pgn.zst
DENOISR_PHASE2_SEQ_LEN=10
DENOISR_PHASE2_MAX_TRAJECTORIES=30000
DENOISR_PHASE2_BATCH_SIZE=64
DENOISR_PHASE2_EPOCHS=120
DENOISR_PHASE2_LR=0.0003
DENOISR_PHASE2_OUTPUT=outputs/phase2.pt

# Phase 3
DENOISR_PHASE3_CHECKPOINT=outputs/phase2.pt
DENOISR_PHASE3_GENERATIONS=400
DENOISR_PHASE3_GAMES_PER_GEN=64
DENOISR_PHASE3_REANALYSE_PER_GEN=32
DENOISR_PHASE3_MCTS_SIMS=400
DENOISR_PHASE3_BUFFER_CAPACITY=50000
DENOISR_PHASE3_ALPHA_GENERATIONS=40
DENOISR_PHASE3_LR=0.0001
DENOISR_PHASE3_TRAIN_BATCH_SIZE=128
DENOISR_PHASE3_DIFFUSION_STEPS=8
DENOISR_PHASE3_AUX_UPDATES_PER_GEN=1
DENOISR_PHASE3_AUX_BATCH_SIZE=64
DENOISR_PHASE3_AUX_SEQ_LEN=10
# Optional override; defaults to DENOISR_PHASE3_LR when unset
# DENOISR_PHASE3_AUX_LR=0.0001
DENOISR_PHASE3_SELF_PLAY_WORKERS=8
DENOISR_PHASE3_REANALYSE_WORKERS=8
DENOISR_PHASE3_OUTPUT=outputs/phase3.pt
DENOISR_PHASE3_SAVE_EVERY=10

# Data generation CLI extras
DENOISR_DATA_OUTPUT=outputs/training_data.pt
DENOISR_POLICY_TEMPERATURE=80.0
DENOISR_LABEL_SMOOTHING=0.02
# Optional random seed
# DENOISR_SEED=42

# Init / export utilities
DENOISR_INIT_OUTPUT=outputs/init_model.pt
DENOISR_EXPORT_CHECKPOINT=outputs/phase3.pt
DENOISR_EXPORT_OUTPUT=outputs/model.safetensors

# UCI / GUI defaults
DENOISR_PLAY_MODE=single
DENOISR_PLAY_DENOISING_STEPS=20
# DENOISR_PLAY_CHECKPOINT=outputs/phase3.pt
DENOISR_GUI_MODE=single
# DENOISR_GUI_CHECKPOINT=outputs/phase3.pt
